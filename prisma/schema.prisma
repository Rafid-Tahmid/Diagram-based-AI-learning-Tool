generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id
  topic     String
  domain    String   @default("general")
  createdAt DateTime @default(now())
  nodes     Node[]
}

model Node {
  id          String      @id @default(uuid())
  sessionId   String
  parentId    String?
  title       String
  description String?
  hasDiagram  Boolean     @default(false)
  status      String      @default("stub")
  createdAt   DateTime    @default(now())
  qaMessages  QAMessage[]
  session     Session     @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([parentId])
}

model QAMessage {
  id        String   @id @default(uuid())
  nodeId    String
  role      String
  content   String
  diagram   Json?
  sources   Json?
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
}

model Doc {
  id         String   @id @default(uuid())
  source     String
  url        String   @unique
  title      String
  breadcrumb String
  language   String?
  fetchedAt  DateTime @default(now())
  chunks     Chunk[]

  @@index([source])
}

model Chunk {
  id      String  @id @default(uuid())
  docId   String
  ordinal Int
  content String
  isCode  Boolean @default(false)
  tokens  Int
  doc     Doc     @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId])
}
