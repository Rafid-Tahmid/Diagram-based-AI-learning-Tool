generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Node {
  id          String   @id @default(uuid())
  sessionId   String
  parentId    String?
  title       String
  description String?
  hasDiagram  Boolean  @default(false)
  status      String   @default("stub")
  createdAt   DateTime @default(now())

  @@index([sessionId])
  @@index([parentId])
}
