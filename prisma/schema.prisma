generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id
  topic     String
  domain    String   @default("general")
  createdAt DateTime @default(now())
  nodes     Node[]
}

model Node {
  id          String      @id @default(uuid())
  sessionId   String
  parentId    String?
  title       String
  description String?
  hasDiagram  Boolean     @default(false)
  status      String      @default("stub")
  // Sibling order within a parent. Set from the planner's foundational→advanced
  // list at creation. Needed because createMany stamps siblings with identical
  // createdAt and id is a random uuid — without this the learning-path order is
  // lost on the DB round-trip.
  ordinal     Int         @default(0)
  // Learner progress, distinct from generation status: "unread" (stub) →
  // "learning" (description generated) → "mastered" (quiz passed).
  mastery     String      @default("unread")
  createdAt   DateTime    @default(now())
  qaMessages  QAMessage[]
  quiz        Quiz?
  session     Session     @relation(fields: [sessionId], references: [id])

  @@index([sessionId])
  @@index([parentId])
}

model QAMessage {
  id        String   @id @default(uuid())
  nodeId    String
  role      String
  content   String
  diagram   Json?
  sources   Json?
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id])

  @@index([nodeId])
}

model Doc {
  id         String   @id @default(uuid())
  source     String
  url        String   @unique
  title      String
  breadcrumb String
  language   String?
  fetchedAt  DateTime @default(now())
  chunks     Chunk[]

  @@index([source])
}

model Chunk {
  id      String  @id @default(uuid())
  docId   String
  ordinal Int
  content String
  isCode  Boolean @default(false)
  tokens  Int
  doc     Doc     @relation(fields: [docId], references: [id], onDelete: Cascade)
  // NOTE: a `vector(3072) embedding` column also exists on this table, added via
  // prisma/sql/001_pgvector.sql (Prisma 5 has no vector type). It is NOT in this
  // schema, so `prisma db push` will not recreate it — re-run that SQL after any
  // push that rebuilds Chunk.

  @@index([docId])
}

// One lazily-generated quiz per node. Questions Json holds the full shape
// including correctIndex — NEVER returned to the client before grading; the
// quiz API strips answers from GET/generate responses and grades server-side.
model Quiz {
  id        String   @id @default(uuid())
  nodeId    String   @unique
  questions Json
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id], onDelete: Cascade)
}

// One telemetry row per AI call (and per cache hit, with cacheHit=true and
// zero tokens). Powers the /settings usage dashboard. Token counts come from
// provider responses when available; null means the provider didn't report.
model Usage {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  taskType     String
  phase        String
  provider     String
  model        String
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int
  grounded     Boolean  @default(false)
  retried      Boolean  @default(false)
  cacheHit     Boolean  @default(false)

  @@index([createdAt])
  @@index([phase])
}

// Cross-session description cache. Key = normalized "ancestorPath > title".
// A repeat topic serves its description from here instead of a fresh grounded
// generation — descriptions of stable educational concepts rarely change.
model DescCache {
  id          String   @id @default(uuid())
  key         String
  domain      String
  description String
  sources     Json?
  confidence  String?
  createdAt   DateTime @default(now())

  @@unique([key, domain])
}

// Cached learning-path STRUCTURE keyed by question — lets a repeat topic skip the
// strong-tier planning call. Separate from the Doc/Chunk grounding corpus on
// purpose: a curriculum skeleton must never surface as a retrieval chunk in Q&A.
// `topic` is normalized (lowercased, trimmed, whitespace-collapsed) before lookup.
model PlanCache {
  id        String   @id @default(uuid())
  topic     String
  domain    String
  plan      Json // { needsDiagram: boolean, children: string[] } — titles only
  createdAt DateTime @default(now())

  @@unique([topic, domain])
}
